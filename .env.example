# Copy this to .env and fill in your values

# daricomma API bearer token (without "Bearer " prefix)
DARICOMMA_TOKEN=eyJhbGciOi...

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OpenRouter (for Gemini)
OPENROUTER_API_KEY=sk-or-v1-...
GEMINI_MODEL=google/gemini-2.0-flash-001
# Delay between Gemini calls per worker (0 = no delay; paid API, rely on built-in 429 retry)
GEMINI_RATE_LIMIT_MS=0
# Number of questions processed in parallel during the Gemini phase
GEMINI_CONCURRENCY=8

# Server
PORT=3939
